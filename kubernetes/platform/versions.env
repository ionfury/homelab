# SINGLE SOURCE OF TRUTH for ALL platform versions
# - Terragrunt reads for infrastructure (talos, k8s, cilium bootstrap)
# - Flux substitutes into helm-charts.yaml for chart versions
# - Tuppr reads for upgrade execution
# - Renovate updates this file (via inline comment annotations)

# Infrastructure versions (Terragrunt + Tuppr)
# renovate: datasource=github-releases depName=talos packageName=siderolabs/talos
talos_version=v1.12.4
# renovate: datasource=github-tags depName=kubernetes packageName=kubernetes/kubernetes extractVersion=^v(?<version>.*)$
kubernetes_version=1.35.1
# renovate: datasource=github-releases depName=cilium packageName=cilium/cilium extractVersion=^v(?<version>.*)$
cilium_version=1.19.1
# renovate: datasource=github-releases depName=gateway-api packageName=kubernetes-sigs/gateway-api
gateway_api_version=v1.4.1
# renovate: datasource=github-releases depName=flux packageName=fluxcd/flux2
flux_version=v2.7.5
# renovate: datasource=helm depName=prometheus-operator-crds registryUrl=https://prometheus-community.github.io/helm-charts
prometheus_version=27.0.0

# Helm chart versions (Flux substitution)
# renovate: datasource=helm depName=cert-manager extractVersion=^v(?<version>.*)$ registryUrl=https://charts.jetstack.io
