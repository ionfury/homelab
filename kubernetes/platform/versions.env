# SINGLE SOURCE OF TRUTH for ALL platform versions
# - Terragrunt reads for infrastructure (talos, k8s, cilium bootstrap)
# - Flux substitutes into helm-charts.yaml for chart versions
# - Tuppr reads for upgrade execution
# - Renovate updates this file (via inline comment annotations)

# Infrastructure versions (Terragrunt + Tuppr)
# renovate: datasource=github-releases depName=talos packageName=siderolabs/talos
talos_version=v1.12.2
# renovate: datasource=github-tags depName=kubernetes packageName=kubernetes/kubernetes extractVersion=^v(?<version>.*)$
kubernetes_version=1.35.0
# renovate: datasource=github-releases depName=cilium packageName=cilium/cilium extractVersion=^v(?<version>.*)$
cilium_version=1.18.6
# renovate: datasource=github-releases depName=gateway-api packageName=kubernetes-sigs/gateway-api
gateway_api_version=v1.4.1
# renovate: datasource=github-releases depName=flux packageName=fluxcd/flux2
flux_version=v2.7.5
# renovate: datasource=helm depName=prometheus-operator-crds registryUrl=https://prometheus-community.github.io/helm-charts
prometheus_version=27.0.0

# Helm chart versions (Flux substitution)
# renovate: datasource=helm depName=cert-manager extractVersion=^v(?<version>.*)$ registryUrl=https://charts.jetstack.io
cert_manager_version=1.19.3
# renovate: datasource=helm depName=external-secrets registryUrl=https://charts.external-secrets.io
external_secrets_version=2.0.0
# renovate: datasource=helm depName=descheduler registryUrl=https://kubernetes-sigs.github.io/descheduler
descheduler_version=0.34.0
# renovate: datasource=helm depName=longhorn registryUrl=https://charts.longhorn.io
longhorn_version=1.11.0
# renovate: datasource=helm depName=reloader registryUrl=https://stakater.github.io/stakater-charts
reloader_version=2.2.7
# renovate: datasource=helm depName=kubernetes-replicator registryUrl=https://helm.mittwald.de
replicator_version=2.12.2
# renovate: datasource=helm depName=kubernetes-secret-generator registryUrl=https://helm.mittwald.de
secret_generator_version=3.4.1
# renovate: datasource=helm depName=canary-checker registryUrl=https://flanksource.github.io/charts
canary_checker_version=1.1.2
# renovate: datasource=helm depName=kube-prometheus-stack registryUrl=https://prometheus-community.github.io/helm-charts
kube_prometheus_stack_version=81.5.0
# renovate: datasource=helm depName=loki registryUrl=https://grafana.github.io/helm-charts
loki_version=6.52.0
# renovate: datasource=helm depName=alloy registryUrl=https://grafana.github.io/helm-charts
alloy_version=1.6.0
# renovate: datasource=helm depName=grafana registryUrl=https://grafana.github.io/helm-charts
grafana_version=10.5.15
# renovate: datasource=helm depName=base registryUrl=https://istio-release.storage.googleapis.com/charts
istio_version=1.28.3
# renovate: datasource=helm depName=cert-manager-istio-csr registryUrl=https://charts.jetstack.io
istio_csr_version=0.15.0
# renovate: datasource=docker depName=garage-operator packageName=ghcr.io/rajsinghtech/charts/garage-operator
garage_operator_version=0.0.32
# renovate: datasource=helm depName=cloudnative-pg registryUrl=https://cloudnative-pg.github.io/charts
cloudnative_pg_version=0.27.1
# renovate: datasource=docker depName=dragonfly-operator packageName=ghcr.io/dragonflydb/dragonfly-operator/helm/dragonfly-operator
dragonfly_operator_version=v1.4.0
# renovate: datasource=docker depName=app-template packageName=ghcr.io/bjw-s-labs/helm/app-template
app_template_version=4.6.2
# renovate: datasource=docker depName=spegel packageName=ghcr.io/spegel-org/helm-charts/spegel
spegel_version=0.6.0
# renovate: datasource=docker depName=tuppr packageName=ghcr.io/home-operations/charts/tuppr
